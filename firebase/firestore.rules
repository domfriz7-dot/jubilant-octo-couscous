rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    // Each user can read and write only their own document.
    // We intentionally do NOT allow listing the collection — user lookup by
    // email is handled server-side via the findUserByEmail Cloud Function.
    match /users/{userId} {
      allow get:   if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Events ─────────────────────────────────────────────────────────────
    // Owner can read/write; users in sharedWith can read.
    match /events/{eventId} {
      allow read: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid ||
         request.auth.uid in resource.data.sharedWith);
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // ── Connections ─────────────────────────────────────────────────────────
    // Both parties can read; either can update (e.g. future block/remove).
    // Clients create connections as part of the acceptInvitation flow.
    match /connections/{connectionId} {
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid   == request.auth.uid);
      allow create: if request.auth != null &&
        (request.resource.data.fromUid == request.auth.uid ||
         request.resource.data.toUid   == request.auth.uid);
      allow update: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid   == request.auth.uid);
      allow delete: if false; // preserve audit trail — soft-delete via status
    }

    // ── Invitations ─────────────────────────────────────────────────────────
    // Sender can create and read their outgoing invites.
    // Both sender and recipient can read / update.
    // Recipients are matched by uid OR by email so that pre-registration
    // invitations (sent before the recipient has an account) are still
    // accessible once they sign up. request.auth.token.email is the verified
    // email from the Firebase Auth ID token.
    // No hard deletes — keeps audit trail and prevents re-invite spam.
    match /invitations/{inviteId} {
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid   == request.auth.uid ||
         resource.data.toEmail == request.auth.token.email);
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.status  == 'pending' &&
        request.resource.data.fromUid != request.resource.data.toUid;
      allow update: if request.auth != null &&
        // Either party by uid, or recipient matched by email (pre-registration)
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid   == request.auth.uid ||
         resource.data.toEmail == request.auth.token.email) &&
        // Only status, updatedAt and toUid may change after creation
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'toUid']) &&
        // toUid may only be claimed by the current user (cannot redirect invite)
        (request.resource.data.toUid == resource.data.toUid ||
         request.resource.data.toUid == request.auth.uid);
      allow delete: if false;
    }
  }
}
