/**
 * AIDatePlannerService
 * 
 * Generates personalized date plans using Claude AI (Anthropic).
 * Integrates with Google Places for real venue data and enrichment.
 * 
 * Features:
 * - Context-aware date planning (budget, mood, preferences)
 * - Real venue suggestions via Google Places API
 * - Travel time and distance calculations
 * - Regeneration with variety (avoids repeating suggestions)
 * - User feedback tracking for improvements
 */

import { getAIConfig } from '../config/ai';
import GooglePlacesService from './GooglePlacesService';
import { logError, logEvent } from './logger';
import { callCallable } from './backend/firebaseFunctions';
import type {
  DatePlanRequest,
  DatePlan,
  DateActivity,
  DateMood,
} from '../types/aiDatePlanner';

// ─── Types ─────────────────────────────────────────────────────

interface ClaudeMessage {
  role: 'user' | 'assistant';
  content: string;
}

interface ClaudeResponse {
  content: Array<{
    type: 'text';
    text: string;
  }>;
  id: string;
  model: string;
  role: 'assistant';
  stop_reason: string;
  stop_sequence: null | string;
  type: 'message';
  usage: {
    input_tokens: number;
    output_tokens: number;
  };
}

interface RawDatePlan {
  title: string;
  description: string;
  mood?: string;
  activities: Array<{
    time: string;
    title: string;
    description: string;
    locationName: string;
    locationAddress: string;
    cost: number;
    duration: number;
    category: string;
    requiresBooking: boolean;
  }>;
}

// ─── Service Class ─────────────────────────────────────────────

class AIDatePlannerService {
  private readonly apiKey: string;
  private readonly model: string;
  private readonly maxTokens: number;
  private readonly temperature: number;
  private readonly baseUrl = 'https://api.anthropic.com/v1/messages';

  constructor() {
    const config = getAIConfig();
    this.apiKey = config.anthropicApiKey;
    this.model = config.model;
    this.maxTokens = config.maxTokens;
    this.temperature = config.temperature;
  }

  /**
   * Generate a complete date plan using Claude AI
   */
  async generateDatePlan(request: DatePlanRequest): Promise<DatePlan> {
    try {
      // Step 1: Build context-rich prompt
      const prompt = this.buildPrompt(request);

      // Step 2: Call Claude API
      const aiResponse = await this.callClaudeAPI(prompt);

      // Step 3: Parse AI response
      const parsedPlan = this.parseAIResponse(aiResponse);

      // Step 4: Enrich with real place data from Google
      const enrichedPlan = await this.enrichWithPlaceData(parsedPlan, request.location);

      // Step 5: Calculate travel times
      const finalPlan = this.calculateTravelTimes(enrichedPlan);

      // Step 6: Format and return
      return {
        id: Date.now().toString(),
        ...finalPlan,
        mood: request.mood,
        createdAt: new Date(),
        accepted: false,
      };
    } catch (error) {
      logError('AI Date Planner Error:', error);
      throw new Error('Failed to generate date plan. Please try again.');
    }
  }

  /**
   * Regenerate plan with different suggestions
   */
  async regeneratePlan(
    previousPlan: DatePlan,
    request: DatePlanRequest
  ): Promise<DatePlan> {
    // Add previous activities to avoid duplicates
    const avoidActivities = previousPlan.activities.map((a: { location: { name: string } }) => a.location.name);

    const updatedRequest: DatePlanRequest = {
      ...request,
      preferences: {
        ...request.preferences,
        avoidActivities: [
          ...(request.preferences?.avoidActivities || []),
          ...avoidActivities,
        ],
      },
    };

    return this.generateDatePlan(updatedRequest);
  }

  /**
   * Save user feedback for ML improvements (future feature)
   */
  async saveUserFeedback(
    planId: string,
    feedback: {
      liked: boolean;
      rating?: number;
      comments?: string;
    }
  ): Promise<void> {
    // For now, persist locally for debugging + route to error tracking if needed.
    // In production, send to a backend for analysis.
    await logEvent('AIDatePlanner.Feedback', { planId, feedback });
  }

  // ─── Private Methods ───────────────────────────────────────

  /**
   * Build a comprehensive prompt for Claude
   */
  private buildPrompt(request: DatePlanRequest): string {
    const {
      date,
      budget,
      mood,
      moods,
      radiusKm,
      location,
      preferences,
      partnerPreferences,
    } = request;

    const moodLabel = (moods && moods.length > 0) ? moods.join(' + ') : mood;

    const radiusMiles = Math.round(radiusKm * 0.621371 * 10) / 10;

    // Build avoid list
    const avoidList = preferences?.avoidActivities?.length
      ? `\n- AVOID these venues (already suggested): ${preferences.avoidActivities.join(', ')}`
      : '';

    return `You are an expert date planner creating personalized, romantic, and memorable date experiences.

CONTEXT:
- Date: ${date}
- Budget: $${budget} (stay within this limit)
- Mood: ${moodLabel}
- Location: ${location.city}${location.state ? ', ' + location.state : ''}
- Search radius: ${radiusKm}km (${radiusMiles} miles) from the user's current location — ALL venues must be within this radius${avoidList}
${preferences?.dietaryRestrictions?.length ? `- Dietary restrictions: ${preferences.dietaryRestrictions.join(', ')}` : ''}
${preferences?.favoriteCuisines?.length ? `- Favorite cuisines: ${preferences.favoriteCuisines.join(', ')}` : ''}
${preferences?.otherNotes ? `- Special notes: ${preferences.otherNotes}` : ''}
${partnerPreferences ? `- Partner (${partnerPreferences.name}) likes: ${partnerPreferences.likes?.join(', ') || 'Various activities'}` : ''}
${partnerPreferences?.dislikes?.length ? `- Partner dislikes: ${partnerPreferences.dislikes.join(', ')}` : ''}

REQUIREMENTS:
1. Create a date plan with 2-4 activities that flow naturally
2. Stay WITHIN the budget of $${budget} total (be specific with costs)
3. Match the ${moodLabel} mood throughout
4. Include at least one meal (dinner or lunch depending on timing)
5. ALL activities MUST be within ${radiusKm}km (${radiusMiles} miles) of the user's location in ${location.city} — this is a hard constraint
6. Use REAL restaurant and venue names in ${location.city}
7. Suggest realistic start times (e.g., "6:30 PM" for evening dates)
8. Make it special and memorable, not generic

MOOD GUIDELINES:
- romantic: Intimate settings, candlelight, sunset views, quiet spots
- fun: Lively atmosphere, games, entertainment, laughter
- adventurous: New experiences, outdoor activities, exploration
- relaxing: Low-key, comfortable, stress-free, peaceful
- surprise: Mix of unexpected but delightful activities

RESPONSE FORMAT (JSON only, no markdown):
{
  "title": "A catchy title (e.g., 'Romantic Evening in ${location.city}')",
  "description": "One engaging sentence about the experience",
  "activities": [
    {
      "time": "6:30 PM",
      "title": "Activity name",
      "description": "What makes this special (1-2 sentences, sell the experience)",
      "locationName": "Actual venue name in ${location.city}",
      "locationAddress": "Street address",
      "cost": 35,
      "duration": 90,
      "category": "food",
      "requiresBooking": true
    }
  ]
}

IMPORTANT: 
- Return ONLY valid JSON, no markdown code blocks
- Use real venue names from ${location.city}
- Keep total cost under $${budget}
- Make it feel personal and special
- category must be one of: food, activity, entertainment, relaxation

Generate the date plan now:`;
  }

  /**
   * Call Claude API via REST
   */
  private async callClaudeAPI(prompt: string): Promise<string> {
    // Hard timeout so the UI never hangs forever on mobile networks.
    let timer: ReturnType<typeof setTimeout> | null = null;
    const controller = new AbortController();

    try {
      // Prefer Firebase callable so you don't ship secrets in the client.
      // If the app isn't configured for Firebase functions, fall back to direct API
      // only when an API key exists.
      if (!this.apiKey) {
        const r = await callCallable<{ prompt: string }, { text: string }>('aiGeneratePlan', { prompt });
        if (r.ok) return r.value.text;
        throw new Error((r as { error?: { message?: string } }).error?.message || 'Unknown error');
      }

      const timeoutMs = 25000;
      timer = setTimeout(() => controller.abort(), timeoutMs);

      const response = await fetch(this.baseUrl, {
        method: 'POST',
        signal: controller.signal,
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': this.apiKey,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model: this.model,
          max_tokens: this.maxTokens,
          temperature: this.temperature,
          messages: [{ role: 'user', content: prompt }],
        }),
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`Claude API error: ${response.status} - ${errorText}`);
      }

      const data: ClaudeResponse = await response.json();

      if (!data.content || data.content.length === 0) {
        throw new Error('Claude API returned empty response');
      }

      return data.content[0].text;
    } catch (error) {
      logError('Claude API call failed:', error);
      throw error;
    } finally {
      if (timer) clearTimeout(timer);
    }
  }

  /**
   * Parse Claude's JSON response
   */
  private parseAIResponse(aiResponse: string): RawDatePlan {
    try {
      // Remove markdown code blocks if present
      let cleaned = aiResponse
        .replace(/```json\n?/g, '')
        .replace(/```\n?/g, '')
        .trim();

      // Sometimes Claude wraps response in extra text, extract JSON
      const jsonMatch = cleaned.match(/\{[\s\S]*\}/);
      if (jsonMatch) {
        cleaned = jsonMatch[0];
      }

      const parsed = JSON.parse(cleaned);

      // Validate structure
      if (!parsed.title || !parsed.description || !Array.isArray(parsed.activities)) {
        throw new Error('Invalid response structure from AI');
      }

      return parsed as RawDatePlan;
    } catch (error) {
      logError('Failed to parse AI response:', aiResponse.substring(0, 200));
      throw new Error('AI returned invalid response format');
    }
  }

  /**
   * Enrich AI-generated plan with real Google Places data
   */
  private async enrichWithPlaceData(
    plan: RawDatePlan,
    location: { city: string; lat: number; lng: number }
  ): Promise<Omit<DatePlan, 'id' | 'mood' | 'createdAt' | 'accepted'>> {
    const enrichedActivities: DateActivity[] = [];

    for (const activity of plan.activities) {
      try {
        // Search for the actual place using Google Places
        const searchQuery = `${activity.locationName} ${location.city}`;
        const places = await this.searchGooglePlaces(
          searchQuery,
          location.lat,
          location.lng
        );

        let enrichedActivity: DateActivity;

        if (places && places.length > 0) {
          const place = places[0];

          enrichedActivity = {
            time: activity.time,
            title: activity.title,
            description: activity.description,
            location: {
              name: place.name || activity.locationName,
              address: place.vicinity || activity.locationAddress,
              lat: place.lat || location.lat,
              lng: place.lng || location.lng,
              placeId: place.placeId,
            },
            cost: activity.cost,
            duration: activity.duration,
            category: this.normalizeCategory(activity.category),
            bookingInfo: {
              phone: undefined, // Would need Place Details API call
              website: undefined,
              reservationLink: undefined,
              requiresBooking: activity.requiresBooking,
            },
          };
        } else {
          // Fallback if place not found (use AI-provided data)
          enrichedActivity = {
            time: activity.time,
            title: activity.title,
            description: activity.description,
            location: {
              name: activity.locationName,
              address: activity.locationAddress,
              lat: location.lat,
              lng: location.lng,
            },
            cost: activity.cost,
            duration: activity.duration,
            category: this.normalizeCategory(activity.category),
            bookingInfo: {
              requiresBooking: activity.requiresBooking,
            },
          };
        }

        enrichedActivities.push(enrichedActivity);
      } catch (error) {
        logError('Error enriching activity:', error);
        // Use fallback data
        enrichedActivities.push({
          time: activity.time,
          title: activity.title,
          description: activity.description,
          location: {
            name: activity.locationName,
            address: activity.locationAddress,
            lat: location.lat,
            lng: location.lng,
          },
          cost: activity.cost,
          duration: activity.duration,
          category: this.normalizeCategory(activity.category),
          bookingInfo: {
            requiresBooking: activity.requiresBooking,
          },
        });
      }
    }

    const totalCost = enrichedActivities.reduce((sum, act) => sum + act.cost, 0);
    const totalDuration = enrichedActivities.reduce(
      (sum, act) => sum + act.duration,
      0
    );

    return {
      title: plan.title,
      description: plan.description,
      activities: enrichedActivities,
      totalCost,
      totalDuration,
    };
  }

