# Copy this file to .env and fill in values.
# IMPORTANT: Do NOT commit your real .env.

# --- Observability ---
EXPO_PUBLIC_SENTRY_DSN=

# --- Monetization (RevenueCat) ---
EXPO_PUBLIC_REVENUECAT_API_KEY=
# Optional: force pro in dev only (do NOT use in production builds)
EXPO_PUBLIC_FORCE_PRO=0

# --- Firebase (web config) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- AI Date Planner provider (Anthropic Claude API) ---
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_CLAUDE_API_KEY=  # Alias

# --- Analytics (Segment) ---
EXPO_PUBLIC_SEGMENT_WRITE_KEY=

# --- Optional integrations ---
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
