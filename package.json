{
  "name": "uandme",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --project tsconfig.strict.json --noEmit",
    "typecheck:loose": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo-build-properties": "~1.0.10",
    "expo-calendar": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.15",
    "expo-haptics": "~15.0.7",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.12",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.8",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-worklets": "~0.5.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@sentry/react-native": "~7.2.0",
    "firebase": "^11.0.0",
    "react-native-calendars": "^1.1306.0",
    "react-native-purchases": "^8.7.0",
    "react-native-svg": "~15.12.1",
    "react-native-view-shot": "~4.0.0",
    "@segment/analytics-react-native": "^2.21.4",
    "zod": "^3.24.1",
    "@segment/sovran-react-native": "*",
    "@shopify/flash-list": "~2.0.2",
    "@react-native-community/netinfo": "^11.4.1",
    "expo-crypto": "~14.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.6",
    "jest-expo": "~54.0.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "~5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ],
    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/@react-native-async-storage/async-storage.js",
      "^expo-sqlite$": "<rootDir>/expo-sqlite-mock.js"
    }
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "glob": "^10.4.5",
    "rimraf": "^6.0.1",
    "@babel/plugin-proposal-class-properties": "npm:@babel/plugin-transform-class-properties@^7.25.9",
    "@babel/plugin-proposal-nullish-coalescing-operator": "npm:@babel/plugin-transform-nullish-coalescing-operator@^7.25.9",
    "@babel/plugin-proposal-optional-chaining": "npm:@babel/plugin-transform-optional-chaining@^7.25.9"
  }
}
